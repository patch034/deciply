{
  "name": "toolnova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run verify:encoding && npm run verify:blog-dates && prisma generate",
    "build": "next build",
    "build:cloudflare": "npx @opennextjs/cloudflare build && node scripts/prepare-cloudflare-pages.mjs",
    "preview:cloudflare": "npx @opennextjs/cloudflare build && npx @opennextjs/cloudflare preview",
    "deploy:cloudflare": "npx wrangler deploy",
    "deploy": "npm run build:cloudflare && npm run deploy:cloudflare",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "verify:encoding": "node scripts/verify-encoding.mjs",
    "verify:blog-dates": "node scripts/verify-blog-dates.mjs",
    "verify:i18n": "node scripts/verify-i18n.mjs",
    "repair:encoding": "node scripts/repair-encoding.mjs",
    "fix:encoding": "npm run repair:encoding",
    "admin:db": "node scripts/setup-admin-db.mjs",
