    "generate:favicon": "node scripts/generate-favicon-assets.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@prisma/client": "^6.6.0",
    "@vercel/analytics": "^2.0.1",
